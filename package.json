{
  "name": "gf-rental-api",
  "version": "1.0.0",
  "description": "An Car-Rental Api with different booking models.",
  "main": "app.js",
  "scripts": {
    "dev": "nodemon app.js",
    "start": "node app.js",
    "test": "node --test test/**/*.test.js",
    "test:security": "node --test test/security/**/*.test.js",
    "smoke:security": "bash scripts/smoke-security.sh",
    "migration": "sequelize db:migrate",
    "seed": "sequelize db:seed:all",
    "migrate-encryption": "node migrate-encryption.js"
  },
  "author": "Elias Englen",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.16.1",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "dotenv": "^16.4.7",
    "express": "^4.22.2",
    "express-rate-limit": "^8.5.2",
    "express-slow-down": "^2.1.0",
    "express-validator": "^7.2.1",
    "geoip-lite": "^2.0.2",
    "handlebars": "^4.7.8",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "mariadb": "^3.4.0",
    "multer": "2.2.0",
    "mysql2": "^3.12.0",
    "nodemailer": "9.0.1",
    "otplib": "^13.3.0",
    "pdf-lib": "^1.17.1",
    "qrcode": "^1.5.4",
    "request-ip": "^3.3.0",
    "sequelize": "^6.37.8"
  },
  "devDependencies": {
    "nodemon": "^3.1.9",
    "sequelize-cli": "^6.6.2"
  },
  "overrides": {
    "uuid": "^11.1.1"
  }
}
