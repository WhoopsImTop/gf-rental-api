# Copy to smoke-security.env and fill in values:
#   cp scripts/smoke-security.env.example scripts/smoke-security.env
#   set -a && source scripts/smoke-security.env && set +a
#   ./scripts/smoke-security.sh

API_BASE=http://localhost:3000/api

CUSTOMER_EMAIL=customer@example.com
CUSTOMER_PASSWORD=changeme

# Optional: second customer for isolation test
# CUSTOMER_B_EMAIL=customer-b@example.com
# CUSTOMER_B_PASSWORD=changeme

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme

# Optional: contract with uploaded/generated PDF for share-link tests
# CONTRACT_ID=42

CAR_ABO_ID=1
